{
    "name": "hendabastian/laracrud-apigen",
    "description": "Generate complete CRUD APIs for Laravel with Repository pattern, Spatie QueryBuilder, JSON:API pagination, and DTOs.",
    "keywords": [
        "laravel",
        "crud",
        "api",
        "generator",
        "repository",
        "spatie",
        "dto"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Henda Bastian",
            "email": "mail@hendabastian.my.id"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-data": "^4.0",
        "spatie/laravel-query-builder": "^6.0",
        "spatie/laravel-json-api-paginate": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "HendaBastian\\LaracrudApigen\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HendaBastian\\LaracrudApigen\\CrudGeneratorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}